# Supabase Postgres 連線字串 (Transaction pooler, port 6543)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# 管理者 Token：保護 POST/DELETE/refresh 端點。前端在 admin 頁面貼這串。
ADMIN_TOKEN=請換成一組隨機字串

# Anthropic API Key：後端爬蟲用，前端絕對不碰
ANTHROPIC_API_KEY=sk-ant-xxxx
